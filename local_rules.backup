# requirements
# this document is located originally in: /etc/suricata/rules/local.rules
# 1. Log all ICMP packets detected
alert icmp $EXTERNAL_NET any -> $HOME_NET any (msg:"PL4 ICMP Packet Detected"; 
  classtype:icmp-event; 
  sid:1000001; rev:1;)

# 2. Alert when POST commands are detected in HTTP connections
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"PL4 HTTP POST Command Detected"; 
  flow:to_server,established; 
  uri; 
  content:"POST"; 
  classtype:web-application-attack; 
  sid:1000002; rev:1;)

# 3. Port Scanning Detection
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"PA1 Port Scan Detected"; 
  flags:S; 
  threshold:type threshold, track by_src, count 20, seconds 60; 
  classtype:attempted-recon; 
  sid:1000003; rev:1;)

# 4. SQL Injection Detection
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"PA1 SQL Injection Attempt"; 
  flow:to_server,established; 
  uri; 
  content:"SELECT"; nocase; 
  content:"FROM"; nocase; distance:0; 
  classtype:web-application-attack; 
  sid:1000004; rev:1;)

# 5. XSS Attack Detection
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"PA1 XSS Attempt Script Tag"; 
  flow:to_server,established; 
  uri; 
  content:"<script"; nocase; 
  classtype:web-application-attack; 
  sid:1000005; rev:1;)
