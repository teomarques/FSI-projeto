# REQUIREMENTS

# 1. Log all ICMP packets detected
alert icmp $EXTERNAL_NET any -> $HOME_NET any (msg:"PL4 ICMP Packet Detected"; classtype:icmp-event; sid:1000001; rev:1;)

# 2. Alert when POST commands are detected in HTTP connections
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"PL4 HTTP POST Command Detected"; flow:to_server,established; content:"POST"; http_method; classtype:web-application-attack; sid:1000002; rev:1;)

# REQUIREMENTS - Attack Detection

# 3. Port Scanning Detection
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"PA1 Port Scan Detected"; flags:S; threshold:type threshold, track by_src, count 20, seconds 60; classtype:attempted-recon; sid:1000003; rev:1;)

# 4. SQL Injection Detection
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"PA1 SQL Injection Attempt"; flow:to_server,established; content:"SELECT"; http_uri; nocase; content:"FROM"; nocase; distance:0; classtype:web-application-attack; sid:1000004; rev:1;)

# 5. SQL Injection - UNION based
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"PA1 SQL Injection UNION"; flow:to_server,established; content:"UNION"; http_uri; nocase; content:"SELECT"; nocase; distance:0; classtype:web-application-attack; sid:1000005; rev:1;)

# 6. XSS Attack Detection - Script Tag
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"PA1 XSS Attempt Script Tag"; flow:to_server,established; content:"<script"; http_uri; nocase; classtype:web-application-attack; sid:1000006; rev:1;)

# 7. XSS Attack Detection - JavaScript Protocol
alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"PA1 XSS Attempt JavaScript"; flow:to_server,established; content:"javascript:"; http_uri; nocase; classtype:web-application-attack; sid:1000007; rev:1;)
